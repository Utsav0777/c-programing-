int main(){

int start_num,end_num,sum=0;

printf("Enter START and STOP numbers: ");
scanf("%d %d",&start_num,&end_num);

for(start_num;start_num<=end_num;start_num++){

    if(start_num % 2 ==1){
        sum+=start_num;
    }
}

printf("\nThe sum all odd number is %d",sum);


return 0;
}

